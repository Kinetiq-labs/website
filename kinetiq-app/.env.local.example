# Kinetiq Website - Environment Variables Example
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://kinetiq.com
NEXT_PUBLIC_SITE_NAME=Kinetiq

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=contact@kinetiq.com
NEXT_PUBLIC_CONTACT_PHONE=+1 (234) 567-890

# Social Media (Optional)
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/kinetiq
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/kinetiq
NEXT_PUBLIC_GITHUB_URL=https://github.com/kinetiq

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email Service (Optional - for contact form)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password

# Or use SendGrid/Mailgun/etc
# SENDGRID_API_KEY=your-api-key
